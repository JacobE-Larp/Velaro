# Vilaro gateway — Podman Quadlet (rootless)
# Installed by setup-podman.sh into vilaro's ~/.config/containers/systemd/
# {{VILARO_HOME}} is replaced at install time.

[Unit]
Description=Vilaro gateway (rootless Podman)

[Container]
Image=vilaro:local
ContainerName=vilaro
UserNS=keep-id
# Keep container UID/GID aligned with the invoking user so mounted config is readable.
User=%U:%G
Volume={{VILARO_HOME}}/.vilaro:/home/node/.vilaro:Z
EnvironmentFile={{VILARO_HOME}}/.vilaro/.env
Environment=HOME=/home/node
Environment=TERM=xterm-256color
PublishPort=18789:18789
PublishPort=18790:18790
Pull=never
Exec=node dist/index.js gateway --bind lan --port 18789

[Service]
TimeoutStartSec=300
Restart=on-failure

[Install]
WantedBy=default.target
